@echo off
REM ============================================================================
REM RBIDE Build Script
REM RB BASIC (Ronen Blumberg Basic) Integrated Development Environment
REM ============================================================================

echo.
echo ============================================================================
echo Building RBIDE - RB BASIC IDE
echo ============================================================================
echo.

REM Get the parent directory (rbbasic-portable root)
set RBBASIC_ROOT=%~dp0..
pushd "%RBBASIC_ROOT%"
set RBBASIC_ROOT=%CD%
popd

echo RB BASIC Root: %RBBASIC_ROOT%
echo.

REM Check for rbc.config file
set CONFIG_FILE=%RBBASIC_ROOT%\rbc.config
if not exist "%CONFIG_FILE%" (
    echo ERROR: rbc.config not found!
    echo Expected: %CONFIG_FILE%
    echo.
    echo Make sure this folder is inside the rbbasic-portable directory.
    pause
    exit /b 1
)

echo [OK] Found rbc.config
echo.

REM Read MinGW path from rbc.config
echo Reading MinGW configuration...
set MINGW_PATH=
for /f "usebackq tokens=1,* delims==" %%a in ("%CONFIG_FILE%") do (
    if /i "%%a"=="MINGW_PATH" set MINGW_PATH=%%b
)

REM Remove quotes and trim whitespace if present
set MINGW_PATH=%MINGW_PATH:"=%
set MINGW_PATH=%MINGW_PATH: =%

if "%MINGW_PATH%"=="" (
    echo ERROR: MINGW_PATH not found in rbc.config!
    echo.
    echo Expected line in config: MINGW_PATH=mingw32
    pause
    exit /b 1
)

REM Construct full MinGW path
set MINGW=%RBBASIC_ROOT%\%MINGW_PATH%
set GCC=%MINGW%\bin\g++.exe
set WINDRES=%MINGW%\bin\windres.exe

echo MinGW folder: %MINGW%
echo.

REM Check for MinGW32
if not exist "%GCC%" (
    echo ERROR: MinGW32 compiler not found!
    echo Expected: %GCC%
    echo.
    echo The rbc.config specifies: MINGW_PATH=%MINGW_PATH%
    echo But the compiler was not found at that location.
    echo.
    echo Please check your rbc.config file.
    pause
    exit /b 1
)

echo [OK] MinGW32 found at: %MINGW%
echo.

REM Create obj directory if it doesn't exist
if not exist obj mkdir obj

REM Clean old builds
echo Cleaning old build files...
del /Q obj\*.o 2>nul
del /Q obj\*.res 2>nul
del /Q rbide.exe 2>nul

echo.
echo Compiling source files...
echo.

REM Compile resource file (skip if windres or icon is missing)
if exist res\rbide.ico (
    if exist "%WINDRES%" (
        echo   - Compiling resources...
        "%WINDRES%" res\resource.rc -O coff -o obj\resource.res
        if errorlevel 1 (
            echo     WARNING: Resource compilation failed, continuing without icon
            set RESOURCE_OBJ=
        ) else (
            set RESOURCE_OBJ=obj\resource.res
        )
    ) else (
        echo   - Skipping resources (windres not found)
        set RESOURCE_OBJ=
    )
) else (
    echo   - Skipping resources (no icon file found)
    set RESOURCE_OBJ=
)

REM Compile main.cpp
echo   - Compiling main.cpp...
"%GCC%" -c src\main.cpp -o obj\main.o ^
    -std=c++17 -O2 -Wall
if errorlevel 1 goto :build_failed

REM Compile mainwindow.cpp
echo   - Compiling mainwindow.cpp...
"%GCC%" -c src\mainwindow.cpp -o obj\mainwindow.o ^
    -std=c++17 -O2 -Wall ^
    -Ilib\scintilla\include
if errorlevel 1 goto :build_failed

echo.
echo Linking...

REM Link all together
"%GCC%" obj\main.o obj\mainwindow.o %RESOURCE_OBJ% ^
    -o rbide.exe ^
    -mwindows -static-libgcc -static-libstdc++ ^
    -lcomctl32 -lcomdlg32 -luser32 -lgdi32 -lshell32 -lshlwapi ^
    -s

if errorlevel 1 goto :build_failed

echo.
echo ============================================================================
echo Build SUCCESS!
echo ============================================================================
echo.

REM Show file info
if exist rbide.exe (
    echo Created: rbide.exe
    for %%I in (rbide.exe) do echo Size: %%~zI bytes
    echo.
    echo IMPORTANT: You need SciLexer.dll!
    echo.
    echo Download SciLexer.dll from:
    echo   https://www.scintilla.org/ScintillaDownload.html
    echo.
    echo Or get it from Notepad++:
    echo   C:\Program Files\Notepad++\SciLexer.dll
    echo.
    echo Place SciLexer.dll in the same folder as rbide.exe
    echo.
    echo To test RBIDE:
    echo   1. Download and place SciLexer.dll here
    echo   2. Run: rbide.exe
    echo   3. Open a .BAS file
    echo   4. Try F5 to Compile ^& Run
    echo.
) else (
    echo WARNING: rbide.exe not found after build!
)

pause
exit /b 0

:build_failed
echo.
echo ============================================================================
echo Build FAILED!
echo ============================================================================
echo.
echo Check the error messages above.
echo.
pause
exit /b 1
