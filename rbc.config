; RB BASIC (Ronen Blumberg BASIC) Configuration File
; Version 2.0 - Portable Edition
; 
; All paths can be relative to the RB BASIC installation directory
; or absolute paths (e.g., C:\RBBASIC\mingw32)

[Paths]
; Root directory of RB BASIC installation
CompilerRoot=.

; MinGW32 compiler directory (contains bin, lib, include subdirectories)
MinGW32Path=mingw32

; SDL2 library directory
SDL2Path=lib\SDL2-mingw32

; Output directory for temporary build files
OutputPath=output

; Example programs directory
ExamplesPath=examples

[Compiler]
; GCC C compiler executable
GCC=mingw32\bin\gcc.exe

; G++ C++ compiler executable (for building the compiler itself)
GPP=mingw32\bin\g++.exe

; Optimization level (-O0, -O1, -O2, -O3, -Os)
Optimization=-O1

; Warning flags
Warnings=-Wall -Wno-unused-label -Wno-unknown-pragmas

[SDL2]
; SDL2 include directory (contains SDL2/SDL.h)
IncludePath=lib\SDL2-mingw32\i686-w64-mingw32\include

; SDL2 library directory (contains libSDL2.a, libSDL2main.a)
LibPath=lib\SDL2-mingw32\i686-w64-mingw32\lib

; SDL2 binary directory (contains SDL2.dll)
BinPath=lib\SDL2-mingw32\i686-w64-mingw32\bin

[Options]
; Automatically copy SDL2.dll to output directory
AutoCopySDL=true

; Clean up temporary files after compilation
CleanupTemp=false

; Show compilation progress messages
ShowCompileProgress=true

; Verbose output (for debugging compiler issues)
VerboseOutput=false

; ============================================================
; Notes:
; ============================================================
; 
; Path Format:
;   - Use backslashes (\) for Windows paths
;   - Relative paths are relative to CompilerRoot
;   - Absolute paths (e.g., C:\MyPath) work too
;
; Optimization Levels:
;   -O0 = No optimization (fastest compile, slowest runtime)
;   -O1 = Basic optimization (recommended)
;   -O2 = More optimization
;   -O3 = Maximum optimization
;   -Os = Optimize for size
;
; For portable installation:
;   1. Keep all paths relative (no C:\ drives)
;   2. Place RB BASIC folder anywhere (USB drive, laptop, etc.)
;   3. Run rbbasic.exe - it will find everything automatically
;
; ============================================================
